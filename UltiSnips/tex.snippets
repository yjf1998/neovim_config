snippet template "math template"
\documentclass[11pt]{article}
\usepackage{graphicx}
%\usepackage{times}
%\usepackage{mathptmx}
\usepackage{amsmath}
\usepackage{authblk}
\usepackage{geometry}
\usepackage{amssymb}
\usepackage{amsfonts}
\usepackage{mathrsfs}
\usepackage{multirow}
\usepackage{tikz}
\usepackage{dynkin-diagrams}
\usetikzlibrary{matrix,arrows,decorations.pathmorphing}
\geometry{scale=0.9}
\usepackage{amsthm}
\usepackage{thmtools}
\usepackage[ CJKbookmarks=true,
bookmarksnumbered=true,
bookmarksopen=true,
colorlinks,
linkcolor=blue,
anchorcolor=green,
citecolor=blue
]{hyperref}
\theoremstyle{plain}
\newtheorem{thm}{Theorem}[subsection]%
\newtheorem{prop}[thm]{Proposition}%
\newtheorem{lma}[thm]{Lemma}%
\newtheorem{cor}[thm]{Corollary}
\theoremstyle{definition}
\newtheorem{define}[thm]{Definition}%
\newtheorem{eg}[thm]{Example}%
\newtheorem*{rmk}{Remark}
\setlength{\parindent}{0pt}
\begin{document}
\title{Notes}
\author{Yuan Jiangfan}
\date{}
\affil{Shanghai Jiao Tong University}
\maketitle

\end{document}
endsnippet

